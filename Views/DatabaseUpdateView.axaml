<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="QuickRegister.Views.DatabaseUpdateView">

    <Grid x:Name="RootGrid" IsVisible="True"><!-- Toggle database update scherm -->
        <Grid.Background>
            <SolidColorBrush Color="Black" Opacity="0.75"/>
        </Grid.Background>

        <Border Background="White"
                CornerRadius="8"
                Padding="48"
                MaxWidth="420"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel Spacing="16" HorizontalAlignment="Center">

                <TextBlock Text="De volgende lijst(en) komen nog niet overeen met de database:"
                           FontSize="15"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>

                <ItemsControl ItemsSource="{Binding CsvItems}"
                              HorizontalAlignment="Center">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ToggleButton IsChecked="{Binding IsSelected}"
                                         HorizontalAlignment="Center"
                                         Margin="0,4"
                                         Padding="20,8"
                                         FontSize="14">
                                <TextBlock Text="{Binding FileName}"
                                           TextDecorations="Underline"/>
                            </ToggleButton>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Selecteer de bestanden om te updaten"
                           FontSize="13"
                           Foreground="#555555"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>

                <Button Content="Bijwerken"
                        Command="{Binding UpdateCommand}"
                        Background="#2E7D32"
                        Foreground="White"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        FontSize="16"
                        Width="220"
                        Padding="0,12"
                        CornerRadius="6"/>

                <Button Content="Overslaan"
                        Command="{Binding SkipCommand}"
                        Background="#C62828"
                        Foreground="White"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        FontSize="16"
                        Width="220"
                        Padding="0,12"
                        CornerRadius="6"/>

                <TextBlock Text="Bij nu overslaan komt dit scherm weer in beeld bij het opstarten van de app"
                           FontSize="11"
                           Foreground="Gray"
                           TextWrapping="Wrap"
                           MaxWidth="300"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>

            </StackPanel>
        </Border>
    </Grid>

</UserControl>
